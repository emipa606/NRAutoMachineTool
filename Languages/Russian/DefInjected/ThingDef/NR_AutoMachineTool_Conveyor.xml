<?xml version="1.0" encoding="utf-8"?>
<LanguageData>
  <!--The following translations were generated by https://www.deepl.com/-->
  <!-- EN: AutoMachineTool -->
  <NR_AutoMachineTool_ResearchTab.label>AutoMachineTool</NR_AutoMachineTool_ResearchTab.label>
  <!-- EN: BeltConveyor -->
  <Building_NR_AutoMachineTool_BeltConveyor.label>Ленточный конвейер</Building_NR_AutoMachineTool_BeltConveyor.label>
  <!-- EN: Place it in the direction you want to carry.\nPlace the item on top. (Item Puller and AutoMachineTool can be used.)\nThe belt conveyors are connected by vertically adjoining the orientation. -->
  <Building_NR_AutoMachineTool_BeltConveyor.description>Поместите его в том направлении, в котором хотите нести.
Поместите предмет сверху (можно использовать Item Puller и AutoMachineTool).
Ленточные конвейеры соединяются вертикально примыкающими друг к другу по ориентации.</Building_NR_AutoMachineTool_BeltConveyor.description>
  <!-- EN: Underground conveyor exit -->
  <Building_NR_AutoMachineTool_BeltConveyor_ToFloor.label>Выход подземного конвейера</Building_NR_AutoMachineTool_BeltConveyor_ToFloor.label>
  <!-- EN: Connect the ground belt conveyor and underground conveyor.\nIt is an exit to the underground conveyor. -->
  <Building_NR_AutoMachineTool_BeltConveyor_ToFloor.description>Соедините наземный ленточный конвейер и подземный конвейер.
Это выход на подземный конвейер.</Building_NR_AutoMachineTool_BeltConveyor_ToFloor.description>
  <!-- EN: Underground conveyor entrance -->
  <Building_NR_AutoMachineTool_BeltConveyor_ToUnderground.label>Вход в подземный конвейер</Building_NR_AutoMachineTool_BeltConveyor_ToUnderground.label>
  <!-- EN: Connect the ground belt conveyor and underground conveyor.\nIt is the entrance to the underground conveyor. -->
  <Building_NR_AutoMachineTool_BeltConveyor_ToUnderground.description>Соедините наземный ленточный конвейер и подземный конвейер.
Это вход в подземный конвейер.</Building_NR_AutoMachineTool_BeltConveyor_ToUnderground.description>
  <!-- EN: Underground BeltConveyor -->
  <Building_NR_AutoMachineTool_BeltConveyor_Underground.label>Подземный ленточный конвейер</Building_NR_AutoMachineTool_BeltConveyor_Underground.label>
  <!-- EN: Underground BeltConveyor carries items in the basement.\nUnderground BeltConveyor can not move items on the ground as it is.\nConnect to the underground conveyor entrance and exit and use. -->
  <Building_NR_AutoMachineTool_BeltConveyor_Underground.description>Underground BeltConveyor переносит предметы в подвале.
Подземный ленточный конвейер не может перемещать предметы на земле в существующем виде.
Подключите к подземному конвейеру вход и выход и используйте.</Building_NR_AutoMachineTool_BeltConveyor_Underground.description>
  <!-- EN: Wall embedding BeltConveyor -->
  <Building_NR_AutoMachineTool_BeltConveyor_Wall.label>Встраивание в стену BeltConveyor</Building_NR_AutoMachineTool_BeltConveyor_Wall.label>
  <!-- EN: Place it in the direction you want to carry.(In the wall)\nPlace the item on top. (Item Puller and AutoMachineTool can be used.)\nThe belt conveyors are connected by vertically adjoining the orientation. -->
  <Building_NR_AutoMachineTool_BeltConveyor_Wall.description>Поместите его в направлении, в котором хотите нести. (В стену)
Поместите предмет наверх. (Можно использовать Item Puller и AutoMachineTool).
Ленточные конвейеры соединяются по вертикали с ориентацией.</Building_NR_AutoMachineTool_BeltConveyor_Wall.description>
</LanguageData>
